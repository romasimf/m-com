<div class="profile-page">
  <aside class="profile-sidebar">
    <div class="profile-brand">
      <%= image_tag "logo.png", alt: "m.com", class: "profile-brand-logo" %>
    </div>

    <nav class="profile-nav">
      <%= link_to "#", class: "profile-nav-item" do %>
        <%= image_tag "home.png", class: "profile-nav-icon" %>
        <span>Главная</span>
      <% end %>

      <%= link_to "#", class: "profile-nav-item" do %>
        <%= image_tag "settings.png", class: "profile-nav-icon" %>
        <span>Настройки</span>
      <% end %>

      <%= link_to "#", class: "profile-nav-item" do %>
        <%= image_tag "notifications.png", class: "profile-nav-icon" %>
        <span>Уведомления</span>
      <% end %>

      <%= link_to "#", class: "profile-nav-item" do %>
        <%= image_tag "messages.png", class: "profile-nav-icon" %>
        <span>Сообщения</span>
      <% end %>

      <%= link_to profile_path, class: "profile-nav-item active" do %>
        <%= image_tag "profile.png", class: "profile-nav-icon" %>
        <span>Профиль</span>
      <% end %>
    </nav>

    <%= link_to "Публикация", new_post_path, class: "profile-post-btn" %>

    <div class="profile-logout">
      <%= button_to "Выйти",
          destroy_user_session_path,
          method: :delete,
          class: "profile-logout-btn" %>
    </div>
  </aside>

  <main class="profile-main">
    <div class="profile-cover"></div>

    <div class="profile-header">
      <div class="profile-avatar-wrap">
        <%= image_tag "avatar.png", alt: "Аватар", class: "profile-avatar" %>
      </div>

      <div class="profile-info">
        <h1 class="profile-name">
          <%= @user.email.split("@").first.capitalize %>
        </h1>

        <p class="profile-username">
          @<%= @user.email.split("@").first.downcase %>
        </p>

        <div class="profile-stats">
          <span>1мл Подписчиков</span>
          <span>500 Подписок</span>
        </div>
      </div>
    </div>

    <div class="profile-tabs">
      <div class="profile-tab active">Посты</div>
      <div class="profile-tab">Ответы</div>
      <div class="profile-tab">Медиа</div>
      <div class="profile-tab">Лайки</div>
    </div>

    <div class="profile-content">
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <div class="post-card">
            <div class="post-card-date">
              <%= post.created_at.strftime("%d.%m.%Y %H:%M") %>
            </div>

            <% if post.body.present? %>
              <div class="post-card-body">
                <%= simple_format(post.body, {}, wrapper_tag: "div") %>
              </div>
            <% end %>

            <% if post.images.attached? %>
              <div class="post-images-wrap">
                <% post.images.each do |image| %>
                  <%= image_tag image, class: "post-image" %>
                <% end %>
              </div>
            <% end %>

            <div class="post-card-actions">
              <button type="button" class="post-edit-btn">
                Редактировать
              </button>

              <button
                type="button"
                class="post-delete-btn open-delete-modal"
                data-post-id="<%= post.id %>">
                Удалить
              </button>

              <%= form_with url: post_path(post),
                  method: :delete,
                  local: true,
                  html: { id: "delete-form-#{post.id}", style: "display:none;" } do %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="empty-posts-message">
          У вас пока нет постов
        </div>
      <% end %>
    </div>
  </main>

  <aside class="profile-rightbar">
    <input type="text" placeholder="Поиск" class="profile-search">
  </aside>
</div>

<div id="deleteModal" class="delete-modal hidden">
  <div class="delete-modal-content">
    <h3>Удалить пост?</h3>
    <p>Это действие нельзя отменить.</p>

    <div class="delete-modal-actions">
      <button type="button" id="cancelDelete" class="modal-cancel-btn">Отмена</button>
      <button type="button" id="confirmDelete" class="modal-delete-btn">Удалить</button>
    </div>
  </div>
</div>

<script>
  function initDeleteModal() {
    const modal = document.getElementById("deleteModal");
    const cancelBtn = document.getElementById("cancelDelete");
    const confirmBtn = document.getElementById("confirmDelete");

    if (!modal || !cancelBtn || !confirmBtn) return;

    let currentPostId = null;

    document.querySelectorAll(".open-delete-modal").forEach((button) => {
      button.onclick = function () {
        currentPostId = this.dataset.postId;
        modal.classList.remove("hidden");
      };
    });

    cancelBtn.onclick = function () {
      modal.classList.add("hidden");
      currentPostId = null;
    };

    confirmBtn.onclick = function () {
      if (currentPostId) {
        const form = document.getElementById(`delete-form-${currentPostId}`);
        if (form) form.requestSubmit();
      }
    };

    modal.onclick = function (event) {
      if (event.target === modal) {
        modal.classList.add("hidden");
        currentPostId = null;
      }
    };
  }

  document.addEventListener("DOMContentLoaded", initDeleteModal);
  document.addEventListener("turbo:load", initDeleteModal);
</script>